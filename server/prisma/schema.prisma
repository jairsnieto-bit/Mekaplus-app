generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?
  password      String
  role          Role      @default(OPERATOR)
  status        UserStatus @default(ACTIVE)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  
  // ✅ Relación con guías creadas (relación inversa)
  createdGuides Guide[]   @relation("GuideCreator")
  
  // ✅ Relación con auditoría
  auditLogs     AuditLog[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([deletedAt])
}

// ✅ NUEVO: Enum para roles
enum Role {
  ADMIN
  OPERATOR
  MESSENGER
}

// ✅ NUEVO: Enum para estados
enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

// ✅ NUEVO: Modelo para auditoría
model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  module      String   // USERS, GUIDES, SENDERS, etc.
  description String
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Guide {
  id                  String   @id @default(cuid())
  guideNumber         String   @unique
  senderId            String?  // ✅ Relación con Sender
  razonSocial         String
  direccion           String
  localidad           String
  identificacionUsuario String?
  referenciaEntrega   String?
  fechaEntrega        DateTime?
  horaEntrega         String?
  estado              String   @default("PENDIENTE")
  deliveryType        String?  // ENTREGA_EFECTIVA, INTENTO_ENTREGA, etc.
  evidenceImage       String?  // Ruta de la imagen de evidencia
  createdBy           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sender              Sender?  @relation(fields: [senderId], references: [id])
  
  // ✅ CORREGIDO: Relación con User (creador de la guía)
  createdByUser       User     @relation("GuideCreator", fields: [createdBy], references: [id])
  
  // ✅ Relación inversa para historial
  statusHistory       GuideStatusHistory[]

  @@index([senderId])
  @@index([guideNumber])
  @@index([estado])
  @@index([createdAt])
}

model Setting {
  id            String  @id @default(uuid())
  key           String  @unique
  value         String?
  type          String  @default("string")
  description   String?
  updatedAt     DateTime @updatedAt
}

model GuideConfig {
  id              String  @id @default(uuid())
  logo            String?
  primaryColor    String  @default("#0066CC")
  guidePrefix     String  @default("GUIA")
  guideStart      Int     @default(1)
  guideEnd        Int     @default(999999)
  currentNumber   Int     @default(1)
  fieldsEnabled   Json    @default("{\"razonSocial\":true,\"direccion\":true,\"ciudad\":true}")
  updatedAt       DateTime @updatedAt
}

// ✅ Modelo Sender
model Sender {
  id        String   @id @default(cuid())
  name      String
  nit       String?
  address   String?
  phone     String?
  email     String?
  department String?
  isActive  Boolean  @default(true)
  guides    Guide[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([name])
}

// ✅ Historial de cambios de estado de guías
model GuideStatusHistory {
  id             String   @id @default(cuid())
  guideId        String
  previousStatus String
  newStatus      String
  observation    String   // ✅ Observación obligatoria
  deliveryType   String?  // ✅ Tipo de entrega en el historial
  evidenceImage  String?  // ✅ Evidencia en el historial
  changedBy      String   // ID del usuario que hizo el cambio
  createdAt      DateTime @default(now())

  guide          Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
  @@index([createdAt])
}
